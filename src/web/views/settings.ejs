<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings — Content OS</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: #0d1117; color: #e6edf3; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 0; display: flex; min-height: 100vh; }
    .sidebar { width: 240px; background: #161b22; border-right: 1px solid #21262d; padding: 24px 16px; flex-shrink: 0; display: flex; flex-direction: column; }
    .main { flex: 1; padding: 32px; overflow-y: auto; max-width: 700px; }
    .card { background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 28px; margin-bottom: 20px; }
    .nav-link { color: #8b949e; padding: 10px 14px; border-radius: 8px; text-decoration: none; display: flex; align-items: center; gap: 10px; font-size: 14px; font-weight: 500; transition: all 0.2s; margin-bottom: 4px; }
    .nav-link:hover, .nav-link.active { color: #e6edf3; background: #21262d; }
    .input { background: #0d1117; border: 1px solid #30363d; color: #e6edf3; padding: 10px 14px; border-radius: 8px; width: 100%; outline: none; font-size: 14px; box-sizing: border-box; }
    .input:focus { border-color: #388bfd; }
    select.input { cursor: pointer; }
    .btn { background: #238636; color: #fff; padding: 11px 24px; border-radius: 8px; font-weight: 600; font-size: 14px; border: none; cursor: pointer; }
    label { display: block; margin-bottom: 6px; font-size: 13px; color: #8b949e; }
  </style>
</head>
<body>
  <div class="sidebar">
    <div style="font-size: 18px; font-weight: 700; margin-bottom: 32px; padding: 0 14px;">⚡ Content OS</div>
    <nav style="flex: 1;">
      <a href="/dashboard" class="nav-link">📊 Dashboard</a>
      <a href="/videos" class="nav-link">🎬 Videos</a>
      <a href="/connect" class="nav-link">🔗 Connections</a>
      <a href="/settings" class="nav-link active">⚙️ Settings</a>
    </nav>
    <div style="border-top: 1px solid #21262d; padding-top: 16px; margin-top: 16px;">
      <div style="font-size: 13px; color: #8b949e; padding: 0 14px; margin-bottom: 8px;"><%= user.name %></div>
      <a href="/logout" class="nav-link" style="color: #f85149;">🚪 Sign Out</a>
    </div>
  </div>

  <div class="main">
    <div style="margin-bottom: 32px;">
      <h1 style="font-size: 26px; font-weight: 700; margin: 0 0 4px;">Settings</h1>
      <p style="color: #8b949e; margin: 0;">Configure your content generation preferences</p>
    </div>

    <% if (success) { %>
      <div style="background: #1a4731; border: 1px solid #3fb950; color: #3fb950; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;">✓ Settings saved successfully!</div>
    <% } %>

    <div class="card">
      <h2 style="font-size: 17px; font-weight: 700; margin: 0 0 20px;">Profile</h2>
      <form method="POST" action="/settings">
        <div style="margin-bottom: 16px;">
          <label>Your name</label>
          <input class="input" type="text" name="name" value="<%= user.name %>" required>
        </div>
        <div style="margin-bottom: 16px;">
          <label>Content niche</label>
          <select class="input" name="niche">
            <option value="finance" <%= user.niche === 'finance' ? 'selected' : '' %>>Finance & Money</option>
            <option value="investing" <%= user.niche === 'investing' ? 'selected' : '' %>>Investing & Stocks</option>
            <option value="crypto" <%= user.niche === 'crypto' ? 'selected' : '' %>>Crypto & Web3</option>
            <option value="business" <%= user.niche === 'business' ? 'selected' : '' %>>Business & Entrepreneurship</option>
            <option value="selfimprovement" <%= user.niche === 'selfimprovement' ? 'selected' : '' %>>Self Improvement</option>
          </select>
        </div>
        <div style="margin-bottom: 16px;">
          <label>Content tone</label>
          <select class="input" name="tone">
            <option value="authoritative_yet_accessible" <%= user.tone === 'authoritative_yet_accessible' ? 'selected' : '' %>>Authoritative yet Accessible</option>
            <option value="casual_friendly" <%= user.tone === 'casual_friendly' ? 'selected' : '' %>>Casual & Friendly</option>
            <option value="professional_formal" <%= user.tone === 'professional_formal' ? 'selected' : '' %>>Professional & Formal</option>
            <option value="motivational_energetic" <%= user.tone === 'motivational_energetic' ? 'selected' : '' %>>Motivational & Energetic</option>
          </select>
        </div>
        <div style="margin-bottom: 16px;">
          <label>Voice language</label>
          <select class="input" name="voice_language">
            <option value="english"  <%= (user.voice_language || 'english')  === 'english'  ? 'selected' : '' %>>English</option>
            <option value="hindi"    <%= user.voice_language === 'hindi'    ? 'selected' : '' %>>Hindi</option>
            <option value="hinglish" <%= user.voice_language === 'hinglish' ? 'selected' : '' %>>Hinglish (Hindi + English mix)</option>
          </select>
        </div>
        <div style="margin-bottom: 24px;">
          <label>Voice gender</label>
          <select class="input" name="voice_gender">
            <option value="male"   <%= (user.voice_gender || 'male') === 'male'   ? 'selected' : '' %>>Male</option>
            <option value="female" <%= user.voice_gender === 'female' ? 'selected' : '' %>>Female</option>
          </select>
        </div>
        <div style="margin-bottom: 24px; padding: 16px; background: #0d1117; border-radius: 8px; border: 1px solid #30363d;">
          <label style="display: flex; align-items: center; gap: 12px; cursor: pointer; margin: 0;">
            <div style="position: relative; flex-shrink: 0;">
              <input type="checkbox" name="auto_publish" id="auto_publish" <%= user.auto_publish ? 'checked' : '' %> style="opacity: 0; width: 0; height: 0; position: absolute;">
              <div id="toggle-track" onclick="toggleSwitch()" style="width: 44px; height: 24px; background: <%= user.auto_publish ? '#238636' : '#30363d' %>; border-radius: 12px; cursor: pointer; transition: background 0.2s; position: relative;">
                <div id="toggle-thumb" style="position: absolute; top: 3px; left: <%= user.auto_publish ? '23px' : '3px' %>; width: 18px; height: 18px; background: white; border-radius: 50%; transition: left 0.2s;"></div>
              </div>
            </div>
            <div>
              <div style="font-size: 14px; font-weight: 600; color: #e6edf3;">Auto-publish after generation</div>
              <div style="font-size: 12px; color: #8b949e; margin-top: 2px;">When OFF — videos stay as "Generated" so you can preview and publish manually</div>
            </div>
          </label>
        </div>
        <button type="submit" class="btn">Save Settings</button>
      </form>
    </div>
  </div>
  <script>
    function toggleSwitch() {
      const cb = document.getElementById('auto_publish');
      const track = document.getElementById('toggle-track');
      const thumb = document.getElementById('toggle-thumb');
      cb.checked = !cb.checked;
      track.style.background = cb.checked ? '#238636' : '#30363d';
      thumb.style.left = cb.checked ? '23px' : '3px';
    }
  </script>
</body>
</html>
