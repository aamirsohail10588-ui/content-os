<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connect Accounts — Content OS</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { background: #0d1117; color: #e6edf3; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 0; display: flex; min-height: 100vh; }
    .sidebar { width: 240px; background: #161b22; border-right: 1px solid #21262d; padding: 24px 16px; flex-shrink: 0; display: flex; flex-direction: column; }
    .main { flex: 1; padding: 32px; overflow-y: auto; max-width: 760px; }
    .card { background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 28px; margin-bottom: 20px; }
    .nav-link { color: #8b949e; padding: 10px 14px; border-radius: 8px; text-decoration: none; display: flex; align-items: center; gap: 10px; font-size: 14px; font-weight: 500; transition: all 0.2s; margin-bottom: 4px; }
    .nav-link:hover, .nav-link.active { color: #e6edf3; background: #21262d; }
    .btn-red { background: #da3633; color: #fff; padding: 10px 20px; border-radius: 8px; font-weight: 600; border: none; cursor: pointer; }
  </style>
</head>
<body>
  <div class="sidebar">
    <div style="font-size: 18px; font-weight: 700; margin-bottom: 32px; padding: 0 14px;">⚡ Content OS</div>
    <nav style="flex: 1;">
      <a href="/dashboard" class="nav-link">📊 Dashboard</a>
      <a href="/videos" class="nav-link">🎬 Videos</a>
      <a href="/connect" class="nav-link active">🔗 Connections</a>
      <a href="/settings" class="nav-link">⚙️ Settings</a>
    </nav>
    <div style="border-top: 1px solid #21262d; padding-top: 16px; margin-top: 16px;">
      <div style="font-size: 13px; color: #8b949e; padding: 0 14px; margin-bottom: 8px;"><%= user.name %></div>
      <a href="/logout" class="nav-link" style="color: #f85149;">🚪 Sign Out</a>
    </div>
  </div>

  <div class="main">
    <div style="margin-bottom: 32px;">
      <h1 style="font-size: 26px; font-weight: 700; margin: 0 0 4px;">Connected Accounts</h1>
      <p style="color: #8b949e; margin: 0;">Connect your platforms — videos will be auto-published after generation</p>
    </div>

    <% if (success === 'youtube') { %>
      <div style="background: #1a4731; border: 1px solid #3fb950; color: #3fb950; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;">✓ YouTube connected successfully!</div>
    <% } else if (success === 'instagram') { %>
      <div style="background: #1a4731; border: 1px solid #3fb950; color: #3fb950; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;">✓ Instagram connected successfully!</div>
    <% } else if (error) { %>
      <div style="background: #3d0e0e; border: 1px solid #f85149; color: #f85149; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;">
        Connection failed: <strong><%= error %></strong>
      </div>
    <% } %>

    <!-- YouTube -->
    <div class="card">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
        <div style="display: flex; align-items: center; gap: 14px;">
          <div style="width: 48px; height: 48px; background: #1a0505; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px;">▶</div>
          <div>
            <div style="font-size: 18px; font-weight: 700;">YouTube</div>
            <div style="color: #8b949e; font-size: 13px;">Auto-upload as YouTube Shorts</div>
          </div>
        </div>
        <% if (youtube) { %>
          <span style="background: #1a4731; color: #3fb950; padding: 4px 12px; border-radius: 20px; font-size: 13px; font-weight: 600;">✓ Connected</span>
        <% } else { %>
          <span style="background: #21262d; color: #8b949e; padding: 4px 12px; border-radius: 20px; font-size: 13px;">Not connected</span>
        <% } %>
      </div>
      <% if (youtube) { %>
        <div style="background: #0d1117; border-radius: 8px; padding: 14px; margin-bottom: 16px; font-size: 14px;">
          <span style="color: #8b949e;">Channel: </span><span style="font-weight: 600;"><%= youtube.channel_name %></span>
        </div>
        <form method="POST" action="/connect/youtube/disconnect" onsubmit="return confirm('Disconnect YouTube?')">
          <button type="submit" class="btn-red">Disconnect</button>
        </form>
      <% } else { %>
        <p style="color: #8b949e; font-size: 14px; margin: 0 0 16px;">
          Click below — you'll be taken to Google's login page. Sign in with your YouTube account and click Allow. That's it.
        </p>
        <a href="/connect/youtube" style="background: #cc0000; color: #fff; padding: 12px 24px; border-radius: 8px; font-weight: 600; font-size: 14px; text-decoration: none; display: inline-block;">Connect YouTube →</a>
      <% } %>
    </div>

    <!-- Instagram -->
    <div class="card">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
        <div style="display: flex; align-items: center; gap: 14px;">
          <div style="width: 48px; height: 48px; background: linear-gradient(135deg, #833ab4, #fd1d1d, #fcb045); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px;">📷</div>
          <div>
            <div style="font-size: 18px; font-weight: 700;">Instagram</div>
            <div style="color: #8b949e; font-size: 13px;">Auto-post as Instagram Reels</div>
          </div>
        </div>
        <% if (instagram) { %>
          <span style="background: #1a4731; color: #3fb950; padding: 4px 12px; border-radius: 20px; font-size: 13px; font-weight: 600;">✓ Connected</span>
        <% } else { %>
          <span style="background: #21262d; color: #8b949e; padding: 4px 12px; border-radius: 20px; font-size: 13px;">Not connected</span>
        <% } %>
      </div>
      <% if (instagram) { %>
        <div style="background: #0d1117; border-radius: 8px; padding: 14px; margin-bottom: 16px; font-size: 14px;">
          <span style="color: #8b949e;">Account ID: </span><span style="font-weight: 600;"><%= instagram.account_id %></span>
        </div>
        <form method="POST" action="/connect/instagram/disconnect" onsubmit="return confirm('Disconnect Instagram?')">
          <button type="submit" class="btn-red">Disconnect</button>
        </form>
      <% } else { %>
        <p style="color: #8b949e; font-size: 14px; margin: 0 0 14px;">
          Requires an Instagram Professional (Creator or Business) account linked to a Facebook Page.
        </p>
        <div style="background: #0c2d6b; border: 1px solid #388bfd; border-radius: 8px; padding: 14px; margin-bottom: 18px; font-size: 13px; line-height: 1.8; color: #c9d1d9;">
          <strong style="color: #58a6ff;">Get your token in 2 minutes (free):</strong><br>
          1. Go to <a href="https://developers.facebook.com/tools/explorer" target="_blank" style="color: #58a6ff;">developers.facebook.com/tools/explorer</a><br>
          2. Select your App → <strong>Generate User Token</strong><br>
          3. Add permissions: <code style="background:#0d1117;padding:2px 5px;border-radius:4px;color:#79c0ff;">instagram_basic</code> + <code style="background:#0d1117;padding:2px 5px;border-radius:4px;color:#79c0ff;">instagram_content_publish</code><br>
          4. Run <code style="background:#0d1117;padding:2px 5px;border-radius:4px;color:#79c0ff;">GET /me?fields=id</code> → copy the ID as your Account ID
        </div>
        <form method="POST" action="/connect/instagram">
          <div style="margin-bottom: 12px;">
            <label style="display:block;margin-bottom:5px;font-size:13px;color:#8b949e;">Access Token</label>
            <input style="background:#0d1117;border:1px solid #30363d;color:#e6edf3;padding:10px 14px;border-radius:8px;width:100%;outline:none;font-size:14px;box-sizing:border-box;" type="text" name="access_token" placeholder="EAAxxxxxxxx..." required>
          </div>
          <div style="margin-bottom: 18px;">
            <label style="display:block;margin-bottom:5px;font-size:13px;color:#8b949e;">Instagram Account ID</label>
            <input style="background:#0d1117;border:1px solid #30363d;color:#e6edf3;padding:10px 14px;border-radius:8px;width:100%;outline:none;font-size:14px;box-sizing:border-box;" type="text" name="account_id" placeholder="17841xxxxxxxxx" required>
          </div>
          <button type="submit" style="background:linear-gradient(135deg,#833ab4,#fd1d1d,#fcb045);color:#fff;padding:12px 24px;border-radius:8px;font-weight:600;font-size:14px;border:none;cursor:pointer;">Connect Instagram →</button>
        </form>
      <% } %>
    </div>
  </div>
</body>
</html>
